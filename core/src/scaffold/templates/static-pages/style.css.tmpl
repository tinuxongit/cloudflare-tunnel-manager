* { box-sizing: border-box; }
body {
  margin: 0;
  font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
  background: #0a0a0c;
  color: #e7e7ea;
  min-height: 100vh;
  display: grid;
  place-items: center;
  padding: 2rem;
}
main {
  max-width: 640px;
  text-align: center;
}
h1 {
  font-size: clamp(2rem, 6vw, 3.5rem);
  margin: 0 0 1rem;
  background: linear-gradient(180deg, #fff, #aaa);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}
p { color: #9a9aa0; line-height: 1.6; }
code {
  font-family: "Cascadia Mono", "Fira Code", ui-monospace, monospace;
  background: #1a1a1f;
  border: 1px solid #2a2a30;
  padding: 0.15rem 0.4rem;
  border-radius: 4px;
  font-size: 0.9em;
}
